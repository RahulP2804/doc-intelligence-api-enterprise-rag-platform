# ─────────────────────────────────────────────────
# doc-intelligence-api — Environment Configuration
# Copy to .env and fill in real values before running
# ─────────────────────────────────────────────────

# PostgreSQL
DB_NAME=docintellect
DB_USER=docintellect
DB_PASSWORD=changeme_db_password

# Redis (leave blank for no auth in local dev)
REDIS_PASSWORD=

# GCP Vertex AI
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Path to GCP service account JSON on your HOST machine
# This will be mounted read-only into the container
GOOGLE_APPLICATION_CREDENTIALS_HOST_PATH=/path/to/your/gcp-service-account.json

# OpenAI (optional — used only as fallback if Vertex AI fails)
OPENAI_API_KEY=sk-...
